    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="/style.css">
    <style>
        body {
            background-color: rgb(0, 0, 0);
            padding-inline: 2rem;
        }
        .top-collections-container,
        #action-movies-container,
        #drama-movies-container,
        #romance-movies-container {
            background-color: black;
            padding-block: 4rem;
            border-bottom: solid 0.2rem grey;
            overflow-x: scroll;
        }
        #offcanvasDarkNavbar {
            display: flex;
            flex-direction: row;
            justify-content: space-between !important;
        }
        .dropdown-item:hover {
            background-color: cadetblue;
        }
        #user-page-main-container video {
            height: 85vh;
            width: 100%;
            object-fit: cover;
        }
        #user-page-main-container {
            opacity: 0.5;
        }
        .videos {
            width: 18rem;
            height: 15rem;
        }
        .top-collections {
            display: flex;
            gap: 2.5rem;
            overflow-x: scroll;
            scroll-behavior: smooth;
            justify-content: flex-start;
            /* padding-inline: 2rem; */
            padding-block: 2rem;
        }
        .action-movies, .drama-movies, .romance-movies {
            display: flex;
            gap: 2.5rem;
            justify-content: flex-start;
            /* padding-inline: 2rem; */
            padding-block: 4rem;
        }
        .video-container {
            border: solid aliceblue 0.4rem;
            border-radius: 0.5rem;
            padding-inline: 1rem;
            /* position: relative; */
        }
        @keyframes trans {
            /* 50% {
                transform: scaleX(1.01); 
                transform: scaleY(1.3); 
            }
            100% {
                transform: scaleX(1.15);
                transform: scaleY(1.04);
            } */
            /* 100% {
                transform: scaleX(1.03); 
                transform: scaleY(1.4); 
            } */
        }
        .video-container:hover {
            cursor: pointer;
            transition: 0.3s ease-in-out;
            transform: scale(1.1);
            /* animation: trans ease-in-out alternate 1s forwards; */
            box-shadow: 0.3rem 0.3rem 1rem white;
            border-radius: 2rem;
        }
        .movies-category {
            display: flex;
            gap: 3rem;
            align-items: center;
            margin-left: 21rem;
        }
        .movies-category button {
            color: gray;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 600;
        }
        .movies-category button:hover {
            color: rgb(210, 210, 210);
        }
        td {
            padding-right: 10rem !important;
        }
        a {
            text-decoration: none;
        }
        ::-webkit-scrollbar {
            width: 5px;
            background-color: black;
        }

        ::-webkit-scrollbar-thumb {
            background: #7c7c7c;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #555;
        }
    </style>
</head>

