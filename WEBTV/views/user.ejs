    <script>

        function scrollToAction() {
            var actionToScroll = document.getElementById('action-movies-container')
            actionToScroll.scrollIntoView({ behavior: 'smooth' });
        }
        function scrollToDrama() {
            var dramaToScroll = document.getElementById('drama-movies-container');
            dramaToScroll.scrollIntoView({ behavior: 'smooth' });
        }
        function scrollToRomance() {
            var romanceToScroll = document.getElementById('romance-movies-container');
            romanceToScroll.scrollIntoView({ behavior: 'smooth' });
        }

        let mainToScroll = document.querySelector('#user-page-main-container video');
        function scrollToMain() {
            mainToScroll.scrollIntoView({ behavior: 'smooth' });
        }
        
        let videoContainers = document.querySelectorAll('.video-container');
        for(let videoContainer of videoContainers) {
            videoContainer.addEventListener('click',()=>{
                let currentVideo = videoContainer.childNodes;
                scrollToMain();
                console.dir(currentVideo[1]);
                mainToScroll.setAttribute('src',`${currentVideo[1].src}`);
                mainToScroll.webkitRequestFullScreen();
                mainToScroll.setAttribute('muted','false');
            });
        }
        
    </script>
