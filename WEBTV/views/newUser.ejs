<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WebTv - SignUp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav id="newuser-navbar" class="navbar bg-body-tertiary">
        <div class="img-nav-div">
          <a class="" href="http://localhost:3000/webtv">
            <img src="/pic.svg" alt="Netflix" width="180" height="80">
          </a>
        </div>
        <div class="sign-in-nav-div">
            <a href="http://localhost:3000/webtv/sign-in">Sign In</a>
        </div>
    </nav>
    <div id="sign-up-main-div">
        <h2 id="welcome-back-heading">Welcome back!</h2>
        <h2 id="joining-Netflix-heading">Joining WebTv is easy.</h2>
        <h6 id="enter-password-heading">Enter your details and you'll be watching in no time.</h6>

        <form action="http://localhost:3000/webtv/sign-up" id="newUserForm" method="post">
            <div class="form-floating">
                <input type="email" value="<%=email%>" class="form-control" placeholder="Enter your email" name="newEmail" id="new-email-input" required>
                <label for="email-input">
                    Enter your email
                </label>
            </div>

            <div class="form-floating">
                <input type="username" class="form-control" name="newUsername" id="new-username-input" placeholder="Enter your username" required>
                <label for="new-username-input">
                    Enter your username
                </label>
            </div>

            <div class="form-floating">
                <input type="password" class="form-control" name="newPassword" id="new-password-input" placeholder="Enter your password">
                <label for="new-password-input">Enter your password</label>
            </div>

            <button type="submit" id="submit-btn" class="btn btn-danger">Submit</button>
        </form>

    </div>
    <div class="new-user-footer">
        <table>
            <tr>
                <td colspan="4">Questions? Call <a href="#">000-800-919-1694</a></td>
            </tr>
            <tr>
                <td><a href="#">FAQ</a></td>
                <td><a href="#">Help Centre</a></td>
                <td><a href="#">WebTv Shop</a></td>
                <td><a href="#">Terms of Use</a></td>
            </tr>
            <tr>
                <td><a href="#">Privacy</a></td>
                <td><a href="#">Cookie Preferences</a></td>
                <td><a href="#">Corporate Information</a></td>
            </tr>
            <tr>
                <td id="dropdown-td" colspan="4">
                    <select name="language-dropdown" class="language-dropdown">
                        <option value="">Language</option>
                        <option value="English">English</option>
                    </select>
                </td>
            </tr>
        </table>
    </div>

    <script>
        let confirmHeading = document.createElement('h1');
        confirmHeading.innerText='Please Wait';
        let btn = document.querySelector('#submit-btn');
        btn.addEventListener('click',()=>{
            btn.insertAdjacentElement('afterend',confirmHeading);
            setTimeout(() => {
                confirmHeading.innerText=confirmHeading.innerText+'.';
            }, 1000);
            setTimeout(() => {
                confirmHeading.innerText=confirmHeading.innerText+'.';
            }, 2000);
            setTimeout(() => {
                confirmHeading.innerText=confirmHeading.innerText+'.';
            }, 3000);
            setTimeout(() => {
                confirmHeading.innerHTML='new user created successfully';
            }, 4000);
        });
    </script>
</body>
</html>